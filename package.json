    "next-auth": "^4.24.10",
    "openai": "^4.67.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-signature-canvas": "^1.0.7",
    "resend": "^4.8.0",
    "tailwind-merge": "^2.5.4",
