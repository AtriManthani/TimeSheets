generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique
  phone        String?
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile    UserProfile?
  timesheets Timesheet[]
  otpCodes   OtpCode[]
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  type      String    // "REGISTER"
  channel   String    // "email" | "sms"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  firstName          String
  lastName           String
  designation        String
  managerFirstName   String
  managerLastName    String
  managerEmail       String
  managerRole        String
  hrLeadEmail        String
  department         String
  specificDepartment String
  isComplete         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Timesheet {
  id            String    @id @default(cuid())
  userId        String
  weekStartDate DateTime  @db.Date
  weekEndDate   DateTime  @db.Date
  month         Int
  year          Int
  status        String    @default("DRAFT")
  totalHours    Float     @default(0)
  regularHours  Float     @default(0)
  overtimeHours Float     @default(0)
  notes         String?
  signatureData String?
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user    User                       @relation(fields: [userId], references: [id])
  entries TimesheetEntry[]
  session TimesheetInterviewSession?

  @@unique([userId, weekStartDate])
}

model TimesheetEntry {
  id                   String   @id @default(cuid())
  timesheetId          String
  date                 DateTime @db.Date
  dayOfWeek            String
  regularHours         Float    @default(0)
  overtimeHours        Float    @default(0)
  sickHours            Float    @default(0)
  vacationHours        Float    @default(0)
  personalHolidayHours Float    @default(0)
  holidayHours         Float    @default(0)
  fmlaHours            Float    @default(0)
  compTimeEarned       Float    @default(0)
  compTimeUsed         Float    @default(0)
  parentalLeaveHours   Float    @default(0)
  preParlLeaveHours    Float    @default(0)
  otReason             String?
  notes                String?
  totalHours           Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
}

model TimesheetInterviewSession {
  id            String  @id @default(cuid())
  timesheetId   String  @unique
  userId        String
  messages      Json    @default("[]")
  currentStep   String  @default("START")
  collectedData Json    @default("{}")
  isComplete    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
}
