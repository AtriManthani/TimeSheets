# =============================================================
# TIMEFLUX — Environment Variables
# =============================================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Fill in every value marked with <...>
# 3. Never commit .env.local to git
# =============================================================

# ── PostgreSQL (Supabase) ─────────────────────────────────────
# Direct URL (no pgBouncer) — required for Prisma at runtime
# postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/timeflux?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/timeflux?schema=public"

# ── NextAuth ──────────────────────────────────────────────────
# Generate a secret:  openssl rand -base64 32
NEXTAUTH_SECRET="<run: openssl rand -base64 32>"
NEXTAUTH_URL="http://localhost:3000"

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY="sk-proj-..."

# ── OTP — Email (Resend) ──────────────────────────────────────
RESEND_API_KEY="re_..."

# ── OTP — SMS (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1XXXXXXXXXX"

# ── Power Automate ────────────────────────────────────────────
# Your HTTP trigger URL from the Power Automate flow
POWER_AUTOMATE_WEBHOOK_URL="https://prod-xx.westus.logic.azure.com:443/workflows/..."
